    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "jsonc-parser": "^3.3.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
